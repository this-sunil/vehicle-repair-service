    <style>
        :root {
            --accent-color: #ff3e3e; 
            --dark-bg: #0f1113;
            --glass: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--dark-bg);
            color: #fff;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        h1, h2, h3, h4, .navbar-brand {
            font-family: 'Outfit', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .accent { color: var(--accent-color); }

        /* --- Custom Scrollbar --- */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--dark-bg); }
        ::-webkit-scrollbar-thumb { background: var(--accent-color); border-radius: 10px; }

        /* --- Navigation --- */
        .navbar {
            background: rgba(15, 17, 19, 0.9) !important;
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--glass-border);
            padding: 20px 0;
            transition: 0.4s;
        }

          /* Styling to ensure consistency with your existing theme */
    .service-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 45px 30px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        height: 100%;
        backdrop-filter: blur(10px);
    }

    .service-card:hover {
        transform: translateY(-12px);
        border-color: var(--accent-color);
        background: rgba(255, 62, 62, 0.02);
        box-shadow: 0 15px 35px rgba(0,0,0,0.4);
    }

    .icon-box {
        font-size: 3rem;
        margin-bottom: 25px;
        color: var(--accent-color);
        transition: 0.3s;
    }

    .service-card:hover .icon-box {
        transform: scale(1.1);
        text-shadow: 0 0 15px rgba(255, 62, 62, 0.4);
    }

        /* --- Hero Section --- */
        .hero {
            height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.4)), 
                        url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1600') center/cover no-repeat;
            display: flex;
            align-items: center;
            position: relative;
        }

        .hero-title {
            font-size: clamp(3rem, 8vw, 5.5rem);
            font-weight: 800;
            line-height: 0.9;
        }

        /* --- Buttons --- */
        .btn-premium {
            background: var(--accent-color);
            color: white;
            padding: 16px 40px;
            border-radius: 50px;
            font-weight: 700;
            border: none;
            transition: 0.4s;
            text-transform: uppercase;
        }

        .btn-premium:hover {
            box-shadow: 0 0 30px rgba(255, 62, 62, 0.5);
            transform: translateY(-3px);
            color: white;
        }

        /* New Proper Explore Tech Button */
        .btn-outline-custom {
            border: 2px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            padding: 16px 40px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-transform: uppercase;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(5px);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-outline-custom:hover {
            border-color: var(--accent-color);
            background: rgba(255, 62, 62, 0.1);
            color: #fff;
            box-shadow: 0 0 20px rgba(255, 62, 62, 0.2);
            transform: translateY(-3px);
        }

        /* --- Service Cards --- */
        .service-card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 40px;
            transition: all 0.5s ease;
            height: 100%;
        }

        .service-card:hover {
            transform: translateY(-15px);
            border-color: var(--accent-color);
        }

        .icon-box { font-size: 3rem; margin-bottom: 25px; color: var(--accent-color); }

        /* --- Footer & Map --- */
        footer { background: #08090a; padding-top: 80px; border-top: 1px solid var(--glass-border); }
        .map-container { filter: grayscale(1) invert(1) opacity(0.7); border-radius: 20px; overflow: hidden; border: 1px solid var(--glass-border); }
        .footer-link { text-decoration: none; color: #888; transition: 0.3s; display: block; margin-bottom: 10px; }
        .footer-link:hover { color: var(--accent-color); padding-left: 5px; }
        .social-circle { width: 40px; height: 40px; background: var(--glass); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: white; transition: 0.3s; margin-right: 10px; text-decoration: none; }
        .social-circle:hover { background: var(--accent-color); transform: translateY(-5px); }
     /* Navbar specific refinements */
    .navbar {
        background: rgba(15, 17, 19, 0.9) !important;
        backdrop-filter: blur(20px);
        padding: 15px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
