        .navbar-collapse {
            background: #0f1113;
            margin-top: 15px;
            padding: 20px;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.1);
        }
    }
      .glow-icon-wrapper {
        width: 100px;
        height: 100px;
        background: radial-gradient(circle, rgba(255, 62, 62, 0.15) 0%, rgba(255, 62, 62, 0) 70%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        position: relative;
        border-radius: 50%;
        transition: 0.4s ease;
    }

    .glow-icon-wrapper i {
        font-size: 3.2rem;
        background: linear-gradient(135deg, #fff 30%, var(--accent-color) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 0 8px rgba(255, 62, 62, 0.4));
        transition: 0.4s ease;
    }

    /* Hover State */
    .service-card:hover .glow-icon-wrapper {
        background: radial-gradient(circle, rgba(255, 62, 62, 0.3) 0%, rgba(255, 62, 62, 0) 70%);
        transform: scale(1.1);
    }

    .service-card:hover .glow-icon-wrapper i {
        filter: drop-shadow(0 0 15px rgba(255, 62, 62, 0.8));
        background: linear-gradient(135deg, #fff 0%, var(--accent-color) 80%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Card Polish */
    .service-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 28px;
        padding: 50px 30px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
